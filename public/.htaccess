<IfModule mod_headers.c>
  # Empêche Chrome de scroller automatiquement vers un passage de texte
  # (Scroll-to-Text-Fragment, #:~:text=...) que Google ajoute parfois aux
  # liens de résultats de recherche — sinon un clic peut atterrir n'importe
  # où sur la page (ex: le footer) au lieu du haut.
  Header always set Document-Policy "force-load-at-top"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Une seule URL canonique : https://www.finavators.com — sinon
  # http://finavators.com, https://finavators.com, etc. sont indexés comme
  # des sites séparés avec le même contenu (contenu dupliqué pour Google).
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.finavators.com%{REQUEST_URI} [L,R=301]

  # Sers les vrais fichiers (JS, CSS, images, robots.txt, sitemap.xml...) tels quels
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Toute autre route (ex: /contact, /equipe) est gérée par React Router côté client
  RewriteRule ^ index.html [L]
</IfModule>
